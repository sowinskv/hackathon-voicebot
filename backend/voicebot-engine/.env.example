# Voicebot Engine Configuration

# Server
PORT=3000

# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Azure Whisper STT
AZURE_WHISPER_ENDPOINT=https://your-endpoint.openai.azure.com
AZURE_WHISPER_KEY=your_azure_whisper_key

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Gemini LLM
GEMINI_API_KEY=your_gemini_api_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voicebot

# Limits
MAX_CONVERSATION_DURATION_MS=600000
MAX_RETRIES=3
MAX_TURNS=50

# Cost Tracking
COST_THRESHOLD_DOLLARS=0.50
