# Database Configuration
DB_PASSWORD=devpassword123

# ElevenLabs Configuration (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Gemini Configuration (Language Model)
GEMINI_API_KEY=your_gemini_api_key_here

# Azure OpenAI Whisper Diarize Configuration (Speech-to-Text)
AZURE_OPENAI_API_ENDPOINT=your_azure_endpoint_here
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_MODEL=gpt-4o-transcribe-diarize
AZURE_OPENAI_REGION=swedencentral

# LiveKit Configuration (Voice Orchestration) - REQUIRED
# Sign up at: https://cloud.livekit.io
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud

# Node Environment
NODE_ENV=development
